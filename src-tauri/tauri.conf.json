{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stream Hub",
  "version": "0.1.0",
  "identifier": "com.liushihao.streamhub",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Stream Hub",
        "width": 1040,
        "height": 780,
        "minWidth": 860,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "resources/iina-plugin-danmaku",
      "resources/douyu_danmaku_bridge.js",
      "../douyu_extract_playurl.js",
      "../douyu_search_streamers.js",
      "../douyu_to_mpv.py"
    ]
  }
}
